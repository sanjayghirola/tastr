# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
CLIENT_URLS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/tastr?retryWrites=true&w=majority

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars

# ─── Twilio (OTP) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_CURRENCY=INR

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# ─── Facebook OAuth ────────────────────────────────────────────────────────────
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:8000/api/auth/facebook/callback

# ─── Apple OAuth ───────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=your.apple.client.id
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY_LOCATION=./certs/apple_key.p8
APPLE_CALLBACK_URL=http://localhost:8000/api/auth/apple/callback

# ─── Firebase Admin ────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./certs/firebase-service-account.json

# ─── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ─── Google Maps (Geocoding) ───────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Email (optional for P1 — swap in SES/SendGrid later) ─────────────────────
EMAIL_FROM=noreply@tastr.app

# Socket.io
SOCKET_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Google Maps (for ETA / Directions)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
