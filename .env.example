
# ─── SMTP Email (nodemailer) ──────────────────────────────────────────────────
# Gmail example: use App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Tastr
SMTP_FROM_EMAIL=noreply@tastr.app

# For other providers:
# Outlook/Hotmail: smtp.office365.com port 587
# AWS SES:         email-smtp.<region>.amazonaws.com port 587
# Mailgun:         smtp.mailgun.org port 587

# Restaurant & admin portal URLs (used in email links)
RESTAURANT_WEB_URL=http://localhost:3001
ADMIN_WEB_URL=http://localhost:3002
ADMIN_NOTIFICATION_EMAIL=admin@tastr.app
